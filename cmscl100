    <script>
        /* ==========================================================================
           BASE DE DATOS Y AUTOMATIZACIÓN DE CREDENCIALES
           ========================================================================== */
        let DB = {
            articulos: [],
            config: {
                clientId: '4233142660-roq2gcboids59g8oc2rpghfjgr8qgch5.apps.googleusercontent.com',
                apiKey: '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',
                blogId: '1205081332135096231'
            }
        };

        let idArticuloActual = null;
        let idBloggerReal = null;
        let quill = null;

        function cargarDB() {
            const strDB = localStorage.getItem('cms_economia_db');
            if (strDB) {
                try {
                    const parsed = JSON.parse(strDB);
                    if (parsed.articulos) DB.articulos = parsed.articulos;
                    if (parsed.config && parsed.config.clientId) {
                        DB.config = parsed.config;
                    } else {
                        guardarDB();
                    }
                } catch(e) {
                    console.error("Fallo al parsear DB", e);
                }
            } else {
                guardarDB();
            }
        }

        function guardarDB() {
            localStorage.setItem('cms_economia_db', JSON.stringify(DB));
        }

        document.addEventListener('DOMContentLoaded', () => {
            cargarDB();
            inicializarEditorQuill();
            inicializarManejadoresEventos();
            configurarManejadorTemas();
            iniciarAutoGuardado();
            inyectarCredencialesEnPantalla();
            renderizarListadosDeSecciones();
        });

        /* ==========================================================================
           HERRAMIENTAS DE EDICIÓN COMPLETAS (RESTAURADAS AL 100%)
           ========================================================================== */
        function inicializarEditorQuill() {
            quill = new Quill('#editor-wysiwyg', {
                modules: { 
                    toolbar: [
                        [{ 'font': [] }, { 'size': [] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ 'color': [] }, { 'background': [] }],
                        [{ 'script': 'sub'}, { 'script': 'super' }],
                        [{ 'header': [1, 2, 3, 4, 5, 6, false] }, 'blockquote', 'code-block'],
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }, { 'indent': '-1' }, { 'indent': '+1' }],
                        [{ 'direction': 'rtl' }, { 'align': [] }],
                        ['link', 'image', 'video', 'formula'],
                        ['clean']
                    ] 
                },
                placeholder: 'Comienza a redactar tu análisis económico aquí...',
                theme: 'snow'
            });
            quill.on('text-change', ejecutarAnalisisMetricas);
            const barraAutogenerada = document.querySelector('.ql-toolbar');
            if(barraAutogenerada) document.getElementById('toolbar-quill').appendChild(barraAutogenerada);
        }

        /* ==========================================================================
           MANEJADORES DE EVENTOS Y CORRECCIÓN DE NAVEGACIÓN
           ========================================================================== */
        function inicializarManejadoresEventos() {
            const inputTitulo = document.getElementById('articulo-titulo');
            inputTitulo.addEventListener('input', () => {
                document.getElementById('seo-slug').value = generarSlugAmigable(inputTitulo.value);
            });

            document.getElementById('blogger-estado').addEventListener('change', (e) => {
                document.getElementById('grupo-fecha').style.display = e.target.value === 'schedule' ? 'flex' : 'none';
            });

            document.getElementById('btn-guardar-local').addEventListener('click', () => guardarArticuloActual(true));
            document.getElementById('btn-vista-previa').addEventListener('click', abrirModalVistaPrevia);
            document.getElementById('btn-eliminar-articulo').addEventListener('click', clickEliminarArticulo);
            document.getElementById('btn-confirmar-eliminar').addEventListener('click', confirmarMoverAPapelera);
            document.getElementById('btn-duplicar').addEventListener('click', duplicarArticuloActual);
            document.getElementById('btn-vaciar-papelera').addEventListener('click', vaciarPapeleraCompletamente);
            document.getElementById('btn-guardar-config').addEventListener('click', guardarCredencialesAPI);
            
            document.getElementById('btn-blogger-publicar').addEventListener('click', () => prepararConexionBlogger(false));
            document.getElementById('btn-publicar-top').addEventListener('click', () => prepararConexionBlogger(false));
            document.getElementById('btn-sincronizar-blogger').addEventListener('click', () => prepararConexionBlogger(true));

            document.getElementById('btn-lateral-toggle').addEventListener('click', () => {
                document.getElementById('panel-derecho').classList.toggle('abierto');
            });

            // CORRECCIÓN: Los elementos de menú lateral ahora cambian correctamente entre secciones sin interferencias
            document.querySelectorAll('.nav-item').forEach(item => {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    const seccionID = this.getAttribute('data-seccion');
                    
                    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('activo'));
                    this.classList.add('activo');

                    document.querySelectorAll('.vista-seccion').forEach(vista => {
                        vista.classList.remove('activa');
                    });
                    
                    const vistaDestino = document.getElementById(`seccion-${seccionID}`);
                    if (vistaDestino) {
                        vistaDestino.classList.add('activa');
                    }
                    
                    if (seccionID !== 'nuevo') {
                        renderizarListadosDeSecciones();
                    }
                });
            });
        }

        /* ==========================================================================
           GESTIÓN DE CONTENIDO LOCAL
           ========================================================================== */
        function guardarArticuloActual(mostrarAviso = false) {
            const titulo = document.getElementById('articulo-titulo').value.trim();
            const html = quill.getSemanticHTML();

            if(!titulo && html === '<p></p>') return;

            const articuloData = {
                id: idArticuloActual || 'art_' + Date.now(),
                idBloggerReal: idBloggerReal,
                titulo: titulo || 'Artículo sin título',
                contenidoHtml: html,
                seoTitulo: document.getElementById('seo-titulo').value,
                seoSlug: document.getElementById('seo-slug').value,
                seoDescripcion: document.getElementById('seo-descripcion').value,
                bloggerEstado: document.getElementById('blogger-estado').value,
                bloggerFecha: document.getElementById('blogger-fecha').value,
                bloggerCategoria: document.getElementById('blogger-categoria').value,
                bloggerEtiquetas: document.getElementById('blogger-etiquetas').value,
                bloggerImagen: document.getElementById('blogger-imagen').value,
                fechaModificacion: new Date().toISOString(),
                eliminado: false
            };

            const index = DB.articulos.findIndex(a => a.id === articuloData.id);
            if (index !== -1) {
                articuloData.eliminado = DB.articulos[index].eliminado;
                DB.articulos[index] = articuloData;
            } else {
                DB.articulos.push(articuloData);
            }

            idArticuloActual = articuloData.id;
            guardarDB();

            document.getElementById('sync-reloj').textContent = new Date().toLocaleTimeString();
            if (mostrarAviso) mostrarToast('Guardado en la memoria local.', 'exito');
        }

        function editarArticulo(id) {
            const art = DB.articulos.find(a => a.id === id);
            if (!art) return;

            idArticuloActual = art.id;
            idBloggerReal = art.idBloggerReal || null;
            
            document.getElementById('articulo-titulo').value = art.titulo;
            quill.clipboard.dangerouslyPasteHTML(art.contenidoHtml);
            document.getElementById('seo-titulo').value = art.seoTitulo || '';
            document.getElementById('seo-slug').value = art.seoSlug || '';
            document.getElementById('seo-descripcion').value = art.seoDescripcion || '';
            document.getElementById('blogger-estado').value = art.bloggerEstado || 'draft';
            document.getElementById('blogger-fecha').value = art.bloggerFecha || '';
            document.getElementById('blogger-categoria').value = art.bloggerCategoria || '';
            document.getElementById('blogger-etiquetas').value = art.bloggerEtiquetas || '';
            document.getElementById('blogger-imagen').value = art.bloggerImagen || '';

            document.getElementById('grupo-fecha').style.display = art.bloggerEstado === 'schedule' ? 'flex' : 'none';

            // Activa la sección del editor
            const navNuevo = document.querySelector('.nav-item[data-seccion="nuevo"]');
            if (navNuevo) navNuevo.click();
            mostrarToast('Artículo cargado en el editor.', 'info');
        }

        function restaurarArticulo(id) {
            const art = DB.articulos.find(a => a.id === id);
            if (art) { 
                art.eliminado = false; 
                guardarDB(); 
                renderizarListadosDeSecciones(); 
                mostrarToast('Artículo restaurado.', 'exito'); 
            }
        }

        function clickEliminarArticulo() {
            if(!idArticuloActual) { mostrarToast('Editor vacío.', 'error'); return; }
            abrirModal('modal-delete-overlay');
        }

        function confirmarMoverAPapelera() {
            if (idArticuloActual) {
                const index = DB.articulos.findIndex(a => a.id === idArticuloActual);
                if (index !== -1) { DB.articulos[index].eliminado = true; guardarDB(); }
                limpiarEditorCompletamente();
            }
            cerrarModal('modal-delete-overlay');
            renderizarListadosDeSecciones();
        }

        function duplicarArticuloActual() {
            idArticuloActual = null;
            idBloggerReal = null;
            document.getElementById('articulo-titulo').value += ' (Copia)';
            guardarArticuloActual(true);
        }

        function vaciarPapeleraCompletamente() {
            DB.articulos = DB.articulos.filter(a => !a.eliminado);
            guardarDB();
            renderizarListadosDeSecciones();
            mostrarToast('Papelera vaciada.', 'exito');
        }

        function limpiarEditorCompletamente() {
            idArticuloActual = null;
            idBloggerReal = null;
            document.getElementById('articulo-titulo').value = '';
            quill.setText('');
            document.getElementById('seo-titulo').value = '';
            document.getElementById('seo-slug').value = '';
            document.getElementById('seo-descripcion').value = '';
            document.getElementById('blogger-categoria').value = '';
            document.getElementById('blogger-etiquetas').value = '';
            document.getElementById('blogger-imagen').value = '';
        }

        /* ==========================================================================
           CONEXIÓN INTEGRAL CON LA API DE GOOGLE BLOGGER V3 (FORZANDO TU ID)
           ========================================================================== */
        function prepararConexionBlogger(esDescargaSincronizada = false) {
            const activeBlogId = '1205081332135096231';
            if(!DB.config.clientId || !activeBlogId) {
                mostrarToast('Faltan las credenciales en la pestaña Configuración.', 'error');
                return;
            }

            mostrarToast('Abriendo túnel de autenticación Google...', 'info');

            try {
                const tokenClient = google.accounts.oauth2.initTokenClient({
                    client_id: DB.config.clientId,
                    scope: 'https://www.googleapis.com/auth/blogger',
                    callback: (tokenResponse) => {
                        if (tokenResponse.error) {
                            mostrarToast(`Acceso Denegado: ${tokenResponse.error}`, 'error');
                            return;
                        }
                        if(esDescargaSincronizada) {
                            descargarPublicadosDeBlogger(tokenResponse.access_token);
                        } else {
                            subirArticuloABlogger(tokenResponse.access_token);
                        }
                    }
                });
                tokenClient.requestAccessToken({ prompt: 'consent' });
            } catch(err) {
                mostrarToast('Error con la librería Google OAuth SDK.', 'error');
            }
        }

        function descargarPublicadosDeBlogger(accessToken) {
            mostrarToast('Descargando artículos desde la web...', 'info');
            const activeBlogId = '1205081332135096231';
            const url = `https://www.googleapis.com/blogger/v3/blogs/${activeBlogId}/posts?key=${DB.config.apiKey}`;

            fetch(url, {
                method: 'GET',
                headers: { 'Authorization': `Bearer ${accessToken}` }
            })
            .then(res => res.json())
            .then(data => {
                if(data.items && data.items.length > 0) {
                    data.items.forEach(item => {
                        let localArt = DB.articulos.find(a => a.idBloggerReal === item.id);
                        
                        const artEstructura = {
                            id: localArt ? localArt.id : 'art_' + Date.now() + Math.floor(Math.random()*100),
                            idBloggerReal: item.id,
                            titulo: item.title,
                            contenidoHtml: item.content,
                            seoTitulo: item.title,
                            seoSlug: generarSlugAmigable(item.title),
                            seoDescripcion: '',
                            bloggerEstado: 'live',
                            bloggerFecha: item.published,
                            bloggerCategoria: '',
                            bloggerEtiquetas: item.labels ? item.labels.join(', ') : '',
                            bloggerImagen: '',
                            fechaModificacion: item.updated,
                            eliminado: false
                        };

                        if(localArt) {
                            const idx = DB.articulos.findIndex(a => a.id === localArt.id);
                            DB.articulos[idx] = artEstructura;
                        } else {
                            DB.articulos.push(artEstructura);
                        }
                    });
                    guardarDB();
                    renderizarListadosDeSecciones();
                    mostrarToast('¡Sincronización completada con éxito!', 'exito');
                } else {
                    mostrarToast('No se encontraron artículos publicados en Blogger.', 'info');
                }
            })
            .catch(err => mostrarToast('Fallo al leer datos de la API.', 'error'));
        }

        function subirArticuloABlogger(accessToken) {
            mostrarToast('Subiendo artículo...', 'info');
            const activeBlogId = '1205081332135096231';
            const titulo = document.getElementById('articulo-titulo').value.trim() || 'Sin título';
            let html = quill.getSemanticHTML();

            const imgUrl = document.getElementById('blogger-imagen').value.trim();
            if(imgUrl) html = `<img src="${imgUrl}" style="width:100%; max-height:450px; object-fit:cover; border-radius:8px;" /><br><br>` + html;

            const tags = document.getElementById('blogger-etiquetas').value.split(',').map(t => t.trim()).filter(t => t.length > 0);
            const estado = document.getElementById('blogger-estado').value;

            const payload = {
                kind: "blogger#post",
                blog: { id: activeBlogId },
                title: titulo,
                content: html,
                labels: tags
            };

            let esDraftUrlParam = 'false';
            if (estado === 'draft') {
                esDraftUrlParam = 'true';
            }

            if(estado === 'schedule' && document.getElementById('blogger-fecha').value) {
                payload.published = new Date(document.getElementById('blogger-fecha').value).toISOString();
            }

            let url = `https://www.googleapis.com/blogger/v3/blogs/${activeBlogId}/posts/`;
            let metodo = 'POST';

            if(idBloggerReal) {
                url += idBloggerReal;
                metodo = 'PUT';
            } else {
                url += `?isDraft=${esDraftUrlParam}`;
            }

            fetch(url, {
                method: metodo,
                headers: { 'Authorization': `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => { if(!res.ok) throw new Error(res.status); return res.json(); })
            .then(data => {
                idBloggerReal = data.id;
                guardarArticuloActual();
                mostrarToast('¡Procesado correctamente en la web de Blogger!', 'exito');
            })
            .catch(err => mostrarToast(`Error de envío HTTP: ${err.message}`, 'error'));
        }

        /* ==========================================================================
           RENDERIZADORES VISUALES
           ========================================================================== */
        function renderizarListadosDeSecciones() {
            const contenedores = {
                borradores: document.getElementById('contenedor-borradores'),
                publicados: document.getElementById('contenedor-publicados'),
                programados: document.getElementById('contenedor-programados'),
                papelera: document.getElementById('contenedor-papelera')
            };

            Object.values(contenedores).forEach(c => { if(c) c.innerHTML = ''; });

            const activos = DB.articulos.filter(a => !a.eliminado);
            const eliminados = DB.articulos.filter(a => a.eliminado);

            construirGrid(activos.filter(a => a.bloggerEstado === 'draft'), contenedores.borradores, 'draft');
            construirGrid(activos.filter(a => a.bloggerEstado === 'live'), contenedores.publicados, 'live');
            construirGrid(activos.filter(a => a.bloggerEstado === 'schedule'), contenedores.programados, 'schedule');
            construirGrid(eliminados, contenedores.papelera, 'trash');
        }

        function construirGrid(articulos, contenedor, tipo) {
            if (!contenedor) return;
            if (articulos.length === 0) {
                contenedor.innerHTML = `<div class="vacio-placeholder"><i class="fa-solid fa-folder-open"></i><p>No hay artículos en esta carpeta.</p></div>`;
                return;
            }

            const grid = document.createElement('div');
            grid.className = 'grid-articulos';

            articulos.forEach(art => {
                const tarjeta = document.createElement('div');
                tarjeta.className = 'tarjeta-articulo';
                
                // Evitamos la propagación y aplicamos el click condicional para que la navegación a la edición sea fluida.
                if (tipo !== 'trash') {
                    tarjeta.style.cursor = 'pointer';
                    tarjeta.addEventListener('click', (e) => {
                        // Evita cargar edición si se pulsa sobre botones internos de la tarjeta
                        if (e.target.closest('.btn') || e.target.closest('i')) return;
                        editarArticulo(art.id);
                    });
                }

                tarjeta.innerHTML = `
                    <div class="articulo-info">
                        <div class="articulo-meta-titulo">${art.titulo}</div>
                        <div class="articulo-meta-detalles">
                            <span><i class="fa-solid fa-link"></i> /${art.seoSlug || 'sin-slug'}</span>
                            ${art.idBloggerReal ? `<span><i class="fa-solid fa-cloud"></i> Sincronizado</span>` : ''}
                            <span class="estado-badge badge-${tipo}">${tipo === 'draft' ? 'Borrador' : tipo === 'live' ? 'Publicado' : tipo === 'schedule' ? 'Programado' : 'Papelera'}</span>
                        </div>
                    </div>
                    <div class="articulo-acciones-rapidas">
                        ${tipo === 'trash' ? `<button class="btn" onclick="restaurarArticulo('${art.id}')"><i class="fa-solid fa-rotate-left"></i></button>` : `<button class="btn" onclick="editarArticulo('${art.id}')"><i class="fa-solid fa-pen"></i></button>`}
                    </div>
                `;
                grid.appendChild(tarjeta);
            });
            contenedor.appendChild(grid);
        }

        /* ==========================================================================
           COMPONENTES AUXILIARES
           ========================================================================== */
        function inyectarCredencialesEnPantalla() {
            document.getElementById('cfg-client-id').value = DB.config.clientId;
            document.getElementById('cfg-api-key').value = DB.config.apiKey;
            document.getElementById('cfg-blog-id').value = '1205081332135096231';
        }

        function guardarCredencialesAPI() {
            DB.config.clientId = document.getElementById('cfg-client-id').value.trim();
            DB.config.apiKey = document.getElementById('cfg-api-key').value.trim();
            DB.config.blogId = '1205081332135096231';
            guardarDB();
            mostrarToast('Credenciales guardadas y sincronizadas en caché.', 'exito');
        }

        function toggleTarjeta(header) {
            const contenido = header.nextElementSibling;
            contenido.classList.toggle('oculto');
        }

        function configurarManejadorTemas() {
            document.getElementById('btn-tema').addEventListener('click', () => {
                const tema = document.body.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                document.body.setAttribute('data-theme', tema);
            });
        }

        function generarSlugAmigable(texto) {
            return texto.toLowerCase().trim().replace(/[^a-z0-9 -]/g, '').replace(/\s+/g, '-');
        }

        function ejecutarAnalisisMetricas() {
            if(!quill) return;
            const txt = quill.getText().trim();
            document.getElementById('stat-palabras').textContent = txt.split(/\s+/).filter(p => p.length > 0).length;
            document.getElementById('stat-caracteres').textContent = txt.length === 1 && txt === '\n' ? 0 : txt.length;
        }

        function iniciarAutoGuardado() {
            setInterval(() => { guardarArticuloActual(false); }, 20000);
        }

        function mostrarToast(msg, tipo = 'info') {
            const cont = document.getElementById('toast-contenedor');
            const t = document.createElement('div');
            t.className = `toast ${tipo}`;
            t.innerHTML = `<i class="fa-solid fa-circle-info"></i> <span>${msg}</span>`;
            cont.appendChild(t);
            setTimeout(() => t.remove(), 4000);
        }

        function abrirModal(id) { document.getElementById(id).classList.add('activo'); }
        function cerrarModal(id) { document.getElementById(id).classList.remove('activo'); }

        function abrirModalVistaPrevia() {
            document.getElementById('preview-modal-cuerpo').innerHTML = `<h1>${document.getElementById('articulo-titulo').value}</h1><hr><br>` + quill.getSemanticHTML();
            abrirModal('modal-preview-overlay');
        }
    </script>
</body>
</html>
