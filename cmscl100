<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Economía Liberal CMS - Panel de Control Profesional</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">

    <style>
        /* ==========================================================================
           VARIABLES Y TEMAS
           ========================================================================== */
        :root {
            --bg-principal: #f9fafb;
            --bg-panel: #ffffff;
            --bg-sidebar: #f3f4f6;
            --borde: #e5e7eb;
            --texto-principal: #111827;
            --texto-secundario: #4b5563;
            --texto-muted: #9ca3af;
            --primario: #000000;
            --primario-hover: #1f2937;
            --primario-rgb: 0, 0, 0;
            --exito: #10b981;
            --peligro: #ef4444;
            --sombra: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03);
            --sombra-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --fuente: 'Inter', sans-serif;
            --radio: 8px;
            --transicion: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="dark"] {
            --bg-principal: #0b0f19;
            --bg-panel: #111827;
            --bg-sidebar: #1f2937;
            --borde: #374151;
            --texto-principal: #f9fafb;
            --texto-secundario: #d1d5db;
            --texto-muted: #6b7280;
            --primario: #ffffff;
            --primario-hover: #e5e7eb;
            --primario-rgb: 255, 255, 255;
            --sombra: 0 1px 3px 0 rgba(0, 0, 0, 0.3);
            --sombra-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
        }

        /* ==========================================================================
           ESTILOS GENERALES Y RESET
           ========================================================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--fuente);
            background-color: var(--bg-principal);
            color: var(--texto-principal);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        input, textarea, select, button {
            font-family: var(--fuente);
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--borde);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--texto-muted);
        }

        /* ==========================================================================
           BARRA SUPERIOR (HEADER)
           ========================================================================== */
        .barra-superior {
            height: 64px;
            background-color: var(--bg-panel);
            border-bottom: 1px solid var(--borde);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 40;
            position: relative;
        }

        .branding {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-container-astroup {
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-container-astroup img {
            height: 100%;
            object-fit: contain;
        }

        .app-name {
            font-size: 16px;
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        .header-acciones {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* ==========================================================================
           BOTONES Y ACCIONES
           ========================================================================== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 500;
            border-radius: var(--radio);
            border: 1px solid var(--borde);
            background-color: var(--bg-panel);
            color: var(--texto-principal);
            cursor: pointer;
            transition: var(--transicion);
        }

        .btn:hover {
            background-color: var(--bg-sidebar);
            border-color: var(--texto-muted);
        }

        .btn-primario {
            background-color: var(--primario);
            color: var(--bg-panel);
            border-color: var(--primario);
        }

        .btn-primario:hover {
            background-color: var(--primario-hover);
            border-color: var(--primario-hover);
            color: var(--bg-panel);
        }

        .btn-exito {
            background-color: var(--exito);
            color: white;
            border-color: var(--exito);
        }
        .btn-exito:hover {
            background-color: #059669;
            color: white;
        }

        .btn-peligro {
            color: var(--peligro);
            border-color: var(--borde);
        }

        .btn-peligro:hover {
            background-color: rgba(239, 68, 68, 0.08);
            border-color: var(--peligro);
        }

        .btn-icono {
            width: 36px;
            height: 36px;
            padding: 0;
            border-radius: var(--radio);
        }

        /* ==========================================================================
           CONTENEDOR PRINCIPAL
           ========================================================================== */
        .contenedor-principal {
            display: flex;
            flex: 1;
            height: calc(100vh - 64px);
            overflow: hidden;
            position: relative;
        }

        /* Menú Lateral (Columna 1) */
        .menu-lateral {
            width: 240px;
            background-color: var(--bg-sidebar);
            border-right: 1px solid var(--borde);
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow-y: auto;
            overflow-x: hidden;
            transition: var(--transicion);
        }

        .nav-grupo {
            display: flex;
            flex-direction: column;
            gap: 4px;
            width: 100%;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            color: var(--texto-secundario);
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            border-radius: var(--radio);
            cursor: pointer;
            transition: var(--transicion);
            white-space: nowrap;
        }

        .nav-item:hover, .nav-item.activo {
            background-color: var(--bg-panel);
            color: var(--texto-principal);
            box-shadow: var(--sombra);
        }

        .nav-item i {
            width: 16px;
            text-align: center;
            font-size: 14px;
        }

        /* Zona Central (Columna 2) */
        .zona-central {
            flex: 1;
            background-color: var(--bg-panel);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .vista-seccion {
            display: none;
            width: 100%;
            height: 100%;
            flex-direction: column;
            overflow: hidden;
        }

        .vista-seccion.activa {
            display: flex;
        }

        /* Estilos del Editor */
        .editor-cabecera {
            padding: 24px 32px 16px 32px;
        }

        .input-titulo {
            width: 100%;
            border: none;
            outline: none;
            font-size: 28px;
            font-weight: 700;
            color: var(--texto-principal);
            background: transparent;
            letter-spacing: -0.03em;
        }

        .input-titulo::placeholder {
            color: var(--texto-muted);
            opacity: 0.5;
        }

        .editor-contenedor {
            flex: 1;
            padding: 0 32px 32px 32px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .ql-toolbar.ql-snow {
            border: none !important;
            border-bottom: 1px solid var(--borde) !important;
            padding: 12px 32px !important;
            background-color: var(--bg-panel);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .ql-container.ql-snow {
            border: none !important;
            font-family: var(--fuente) !important;
            font-size: 15px !important;
            color: var(--texto-principal) !important;
            flex: 1;
            margin-top: 16px;
        }

        .ql-editor {
            padding: 0 !important;
            min-height: 300px;
        }

        /* Estilos de las vistas de listados */
        .listado-cabecera {
            padding: 24px 32px;
            border-bottom: 1px solid var(--borde);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .listado-titulo {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .listado-contenido {
            flex: 1;
            overflow-y: auto;
            padding: 24px 32px;
        }

        .grid-articulos {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .tarjeta-articulo {
            background-color: var(--bg-panel);
            border: 1px solid var(--borde);
            border-radius: var(--radio);
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            transition: var(--transicion);
        }

        .tarjeta-articulo:hover {
            border-color: var(--texto-secundario);
            box-shadow: var(--sombra);
            transform: translateY(-1px);
        }

        .articulo-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
        }

        .articulo-meta-titulo {
            font-size: 15px;
            font-weight: 600;
            color: var(--texto-principal);
        }

        .articulo-meta-detalles {
            font-size: 12px;
            color: var(--texto-muted);
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .articulo-acciones-rapidas {
            display: flex;
            gap: 8px;
            margin-left: 16px;
        }

        .estado-badge {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            padding: 2px 8px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
        }

        .badge-draft { background-color: #f3f4f6; color: #4b5563; }
        .badge-live { background-color: #d1fae5; color: #065f46; }
        .badge-schedule { background-color: #e0f2fe; color: #0369a1; }
        .badge-trash { background-color: #fee2e2; color: #991b1b; }

        .vacio-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
            color: var(--texto-muted);
            text-align: center;
            gap: 12px;
        }

        .vacio-placeholder i {
            font-size: 40px;
            opacity: 0.5;
        }

        /* Panel Derecho */
        .panel-derecho {
            width: 340px;
            background-color: var(--bg-principal);
            border-left: 1px solid var(--borde);
            overflow-y: auto !important; /* Desplazamiento nativo asegurado */
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            transition: var(--transicion);
            max-height: calc(100vh - 64px); 
        }

        .tarjeta-widget {
            background-color: var(--bg-panel);
            border: 1px solid var(--borde);
            border-radius: var(--radio);
            box-shadow: var(--sombra);
            overflow: visible !important; /* Evita que el contenedor oculte elementos internos */
        }

        .tarjeta-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--borde);
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            user-select: none;
            background-color: rgba(0,0,0,0.01);
        }

        .tarjeta-titulo {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--texto-secundario);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .tarjeta-contenido {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .tarjeta-contenido.oculto {
            display: none;
        }

        /* Formularios */
        .form-grupo {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-label {
            font-size: 12px;
            font-weight: 500;
            color: var(--texto-secundario);
        }

        .form-control {
            width: 100%;
            padding: 8px 12px;
            font-size: 13px;
            background-color: var(--bg-principal);
            border: 1px solid var(--borde);
            color: var(--texto-principal);
            border-radius: 6px;
            outline: none;
            transition: var(--transicion);
        }

        .form-control:focus {
            border-color: var(--texto-principal);
            box-shadow: 0 0 0 2px rgba(var(--primario-rgb), 0.05);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .stat-box {
            background-color: var(--bg-principal);
            padding: 10px;
            border-radius: 6px;
            border: 1px solid var(--borde);
        }

        .stat-val {
            font-size: 16px;
            font-weight: 600;
            color: var(--texto-principal);
        }

        .stat-lbl {
            font-size: 11px;
            color: var(--texto-muted);
            margin-top: 2px;
        }

        .sync-time {
            font-size: 11px;
            color: var(--texto-muted);
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 4px;
        }

        .widget-acciones {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .widget-acciones .btn {
            width: 100%;
            justify-content: flex-start;
        }

        /* Sistema de Toasts */
        .toast-contenedor {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 100;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background-color: var(--bg-panel);
            color: var(--texto-principal);
            border: 1px solid var(--borde);
            padding: 12px 16px;
            border-radius: var(--radio);
            box-shadow: var(--sombra-md);
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            font-weight: 500;
            min-width: 280px;
            transform: translateY(20px);
            opacity: 0;
            animation: entradaToast 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        .toast.exito i { color: var(--exito); }
        .toast.error i { color: var(--peligro); }
        .toast.info i { color: var(--primario); }

        @keyframes entradaToast {
            to { transform: translateY(0); opacity: 1; }
        }

        /* Modales */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(4px);
            z-index: 90;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease;
        }

        .modal-overlay.activo {
            opacity: 1;
            pointer-events: auto;
        }

        .modal {
            background-color: var(--bg-panel);
            border-radius: 12px;
            box-shadow: var(--sombra-md);
            max-width: 800px;
            width: 90%;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            transform: scale(0.95);
            transition: transform 0.2s ease;
        }

        .modal-overlay.activo .modal { transform: scale(1); }
        .modal-header {
            padding: 16px 24px;
            border-bottom: 1px solid var(--borde);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modal-body {
            padding: 24px;
            overflow-y: auto;
            font-size: 15px;
            line-height: 1.6;
        }

        .modal-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--borde);
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        @media (max-width: 1024px) {
            .panel-derecho {
                position: fixed;
                right: 0;
                top: 64px;
                height: calc(100vh - 64px);
                z-index: 30;
                transform: translateX(100%);
            }
            .panel-derecho.abierto { transform: translateX(0); }
        }
    </style>
</head>
<body data-theme="light">

    <header class="barra-superior">
        <div class="branding">
            <div class="logo-container-astroup">
                <img src="https://www.astroup.es/assets/astroup-logo-CqTw9D0p.png" alt="Astroup Logo">
            </div>
            <span class="app-name">Economia Liberal CMS</span>
        </div>
        <div class="header-acciones">
            <button class="btn btn-icono" id="btn-tema" title="Cambiar Tema">
                <i class="fa-solid fa-moon"></i>
            </button>
            <button class="btn btn-icono" id="btn-lateral-toggle" title="Configuraciones adicionales">
                <i class="fa-solid fa-sliders"></i>
            </button>
            <button class="btn btn-primario" id="btn-publicar-top">
                <i class="fa-solid fa-paper-plane"></i> Publicar en Web
            </button>
        </div>
    </header>

    <main class="contenedor-principal">
        
        <aside class="menu-lateral" id="menu-lateral">
            <div class="nav-grupo">
                <div class="nav-item activo" data-seccion="nuevo">
                    <i class="fa-solid fa-pen-to-square"></i> Nuevo artículo
                </div>
                <div class="nav-item" data-seccion="borradores">
                    <i class="fa-solid fa-file-lines"></i> Borradores
                </div>
                <div class="nav-item" data-seccion="publicados">
                    <i class="fa-solid fa-circle-check"></i> Publicados
                </div>
                <div class="nav-item" data-seccion="programados">
                    <i class="fa-solid fa-clock"></i> Programados
                </div>
                <div class="nav-item" data-seccion="papelera">
                    <i class="fa-solid fa-trash-can"></i> Papelera
                </div>
            </div>
            <div class="nav-grupo" style="margin-top: 20px;">
                <div class="nav-item" data-seccion="configuracion">
                    <i class="fa-solid fa-gear"></i> Configuración API
                </div>
            </div>
        </aside>

        <section class="zona-central">
            
            <div id="seccion-nuevo" class="vista-seccion activa">
                <div class="editor-cabecera">
                    <input type="text" id="articulo-titulo" class="input-titulo" placeholder="Título del artículo..." autocomplete="off">
                </div>
                <div id="toolbar-quill"></div>
                <div class="editor-contenedor">
                    <div id="editor-wysiwyg"></div>
                </div>
            </div>

            <div id="seccion-borradores" class="vista-seccion">
                <div class="listado-cabecera">
                    <h2 class="listado-titulo">Mis Borradores</h2>
                </div>
                <div class="listado-contenido">
                    <div class="grid-articulos" id="contenedor-borradores"></div>
                </div>
            </div>

            <div id="seccion-publicados" class="vista-seccion">
                <div class="listado-cabecera">
                    <h2 class="listado-titulo">Artículos Publicados en la Web</h2>
                    <button class="btn btn-exito" id="btn-sincronizar-blogger">
                        <i class="fa-solid fa-arrows-rotate"></i> Sincronizar con Blogger
                    </button>
                </div>
                <div class="listado-contenido">
                    <div class="grid-articulos" id="contenedor-publicados"></div>
                </div>
            </div>

            <div id="seccion-programados" class="vista-seccion">
                <div class="listado-cabecera">
                    <h2 class="listado-titulo">Artículos Programados</h2>
                </div>
                <div class="listado-contenido">
                    <div class="grid-articulos" id="contenedor-programados"></div>
                </div>
            </div>

            <div id="seccion-papelera" class="vista-seccion">
                <div class="listado-cabecera">
                    <h2 class="listado-titulo">Papelera de Reciclaje</h2>
                    <button class="btn btn-peligro" id="btn-vaciar-papelera"><i class="fa-solid fa-circle-minus"></i> Vaciar Papelera</button>
                </div>
                <div class="listado-contenido">
                    <div class="grid-articulos" id="contenedor-papelera"></div>
                </div>
            </div>

            <div id="seccion-configuracion" class="vista-seccion">
                <div class="listado-cabecera">
                    <h2 class="listado-titulo">Configuración de Integración Blogger</h2>
                </div>
                <div class="listado-contenido">
                    <div class="config-form">
                        <div class="form-grupo">
                            <label class="form-label">Client ID de Google API</label>
                            <input type="text" class="form-control" id="cfg-client-id">
                        </div>
                        <div class="form-grupo">
                            <label class="form-label">API Key de Blogger</label>
                            <input type="password" class="form-control" id="cfg-api-key">
                        </div>
                        <div class="form-grupo">
                            <label class="form-label">Blog ID (Blogger)</label>
                            <input type="text" class="form-control" id="cfg-blog-id">
                        </div>
                        <button class="btn btn-primario" id="btn-guardar-config" style="align-self: flex-start; margin-top: 10px;">
                            <i class="fa-solid fa-floppy-disk"></i> Guardar Credenciales
                        </button>
                    </div>
                </div>
            </div>

        </section>

        <aside class="panel-derecho" id="panel-derecho">
            
            <div class="tarjeta-widget">
                <div class="tarjeta-header" onclick="toggleTarjeta(this)">
                    <span class="tarjeta-titulo"><i class="fa-solid fa-bolt"></i> Acciones</span>
                    <i class="fa-solid fa-chevron-down"></i>
                </div>
                <div class="tarjeta-contenido">
                    <div class="widget-acciones">
                        <button class="btn btn-primario" id="btn-blogger-publicar"><i class="fa-solid fa-cloud-arrow-up"></i> Publicar en Blogger</button>
                        <button class="btn" id="btn-guardar-local"><i class="fa-solid fa-floppy-disk"></i> Guardar borrador</button>
                        <button class="btn" id="btn-vista-previa"><i class="fa-solid fa-eye"></i> Vista previa</button>
                        <button class="btn" id="btn-duplicar"><i class="fa-solid fa-copy"></i> Duplicar artículo</button>
